---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/imagenes/og-aura-perfumes.jpg',
} = Astro.props;

const siteName = 'Aura Perfumes Uruguay';
const fullTitle = title.length > 60 ? title : `${title} | Aura Perfumes Uruguay`;
---

<!doctype html>
<html lang="es-UY" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  <!-- SEO Primario -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Robots -->
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="es_UY" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Geo / Local SEO Uruguay -->
  <meta name="geo.region" content="UY-PA" />
  <meta name="geo.placename" content="Paysandú, Uruguay" />
  <meta name="language" content="Spanish" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconexión a fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Schema.org LocalBusiness + Product -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Aura Perfumes",
      "description": "Perfumes originales para dama y caballero en Paysandú, Uruguay. Perfumes árabes, de diseñador y decants con envío a todo Uruguay.",
      "url": "https://auraperfumes.uy",
      "telephone": "+59899373372",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Paysandú",
        "addressCountry": "UY"
      },
      "sameAs": [
        "https://www.instagram.com/aurabellazayperfumes",
        "https://www.tiktok.com/@velntina.manggini"
      ],
      "priceRange": "$$",
      "openingHours": "Mo-Su 09:00-21:00",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+59899373372",
        "contactType": "customer service",
        "contactOption": "TollFree",
        "availableLanguage": ["Spanish"]
      }
    })}
  </script>
</head>

<body>
