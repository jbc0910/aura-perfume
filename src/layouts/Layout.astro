  <!-- Scripts -->
  <script>
    // ── Navbar: siempre fondo sólido ──
    // Sin efecto scroll; el fondo es siempre el color sólido de la marca.

    // ── Menú mobile ──
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    function isMobile() { return window.innerWidth < 900; }

    function applyNavVisibility() {
      const desktopNav = document.querySelector('.nav-desktop') as HTMLElement | null;
      const ctaBtn = document.querySelector('.header-cta') as HTMLElement | null;
      if (isMobile()) {
        if (desktopNav) desktopNav.style.display = 'none';
        if (ctaBtn) ctaBtn.style.display = 'none';
        if (toggle) toggle.style.display = 'block';
      } else {
        if (desktopNav) desktopNav.style.display = 'flex';
        if (ctaBtn) ctaBtn.style.display = 'inline-flex';
        if (toggle) toggle.style.display = 'none';
        if (mobileMenu) mobileMenu.style.display = 'none';
      }
    }

    applyNavVisibility();
    window.addEventListener('resize', applyNavVisibility);

    toggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.style.display === 'block';
      if (mobileMenu) mobileMenu.style.display = isOpen ? 'none' : 'block';
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });

    // ── FAQ Accordion ──
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        // Cerrar todos
        document.querySelectorAll('.faq-trigger').forEach(t => {
          t.setAttribute('aria-expanded', 'false');
          const content = t.nextElementSibling as HTMLElement | null;
          if (content) content.classList.remove('open');
        });
        // Abrir el clickeado si estaba cerrado
        if (!isExpanded) {
          trigger.setAttribute('aria-expanded', 'true');
          const content = trigger.nextElementSibling as HTMLElement | null;
          if (content) content.classList.add('open');
        }
      });
    });
  </script>

  <!-- GSAP init script -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // Animaciones de entrada al hacer scroll
    gsap.utils.toArray<HTMLElement>('.fade-in-up').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        },
      });
    });

    gsap.utils.toArray<HTMLElement>('.fade-in').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        duration: 1,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        },
      });
    });

    gsap.utils.toArray<HTMLElement>('.scale-in').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        scale: 1,
        duration: 0.8,
        ease: 'back.out(1.5)',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        },
      });
    });
  </script>
</body>
