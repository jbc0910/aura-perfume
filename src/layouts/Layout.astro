<style>
  /* Aseguro que el nav-desktop se oculte en mobile por CSS también */
  @media (max-width: 900px) {
    .nav-desktop { display: none !important; }
    #menu-toggle { display: block !important; }
    .header-cta { display: none !important; }
  }
</style>
