---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Perfumes de Diseñador Originales en Uruguay — Aura Perfumes"
  description="Comprá perfumes de diseñador 100% originales en Uruguay. Chanel, Dior, YSL, Carolina Herrera y más. Envíos desde Paysandú a todo Uruguay. Consultá disponibilidad por WhatsApp."
  canonical="https://auraperfumes.uy/perfumes-disenador"
>

  <!-- ── 1. PROBLEMA / HERO ──────────────────────────────────── -->
  <section
    aria-label="Perfumes de diseñador originales en Uruguay"
    style="
      background:linear-gradient(135deg, #0d0d1a 0%, #1a1535 50%, #0a0d20 100%);
      padding-top:10rem;
      padding-bottom:6rem;
    "
  >
    <div class="container">
      <div style="max-width:700px;">
        <p class="fade-in" style="
          font-size:0.72rem; font-weight:600; letter-spacing:0.3em;
          text-transform:uppercase; color:var(--color-gold); margin-bottom:1.5rem;
          display:flex; align-items:center; gap:0.75rem;
        ">
          <span style="width:2rem; height:1px; background:var(--color-gold); display:inline-block;"></span>
          Marcas internacionales · Uruguay
        </p>
        <h1 class="fade-in-up" style="color:#FAF0E6; margin-bottom:1.5rem;">
          Perfumes de diseñador<br/>
          <em style="color:var(--color-rose); font-style:italic;">100% originales</em><br/>
          al mejor precio de Uruguay
        </h1>
        <p class="fade-in-up" style="color:rgba(255,255,255,0.65); font-size:1.05rem; line-height:1.9; max-width:58ch; margin-bottom:1rem;">
          Las fragancias de las marcas más icónicas del mundo, garantizadas originales y disponibles en Uruguay con envío a domicilio. Sin viajes al duty free, sin precios de boutique de lujo.
        </p>
        <p class="fade-in-up" style="color:rgba(255,255,255,0.45); font-size:0.92rem; line-height:1.8; max-width:55ch;">
          Comprar un perfume de diseñador original en Uruguay siempre fue difícil: poca variedad, precios altísimos en las tiendas locales, o el riesgo de comprar una imitación sin saberlo.
        </p>
      </div>
    </div>
  </section>

  <!-- ── 2. SOLUCIÓN ─────────────────────────────────────────── -->
  <section
    aria-label="Perfumes de diseñador originales con garantía en Uruguay"
    style="background:var(--color-white); padding-block:var(--section-py);"
  >
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">

        <div>
          <p class="section-label fade-in" style="margin-bottom:1rem;">Nuestra propuesta</p>
          <h2 class="fade-in-up" style="margin-bottom:1.5rem;">
            Las marcas que conocés,<br/>con la garantía que merecés
          </h2>
          <p class="fade-in-up" style="color:var(--color-text-muted); line-height:1.9; margin-bottom:1.5rem;">
            En Aura Perfumes manejamos fragancias de diseñador internacionales con <strong>certificado de autenticidad</strong> en cada pieza. Podés consultar disponibilidad de cualquier marca por WhatsApp y Valentina te confirma stock, precio y tiempo de entrega.
          </p>
          <p class="fade-in-up" style="color:var(--color-text-muted); line-height:1.9; margin-bottom:2rem;">
            También ofrecemos <strong>decants de diseñador</strong> para que puedas probar antes de comprar la botella completa. Ideal si querés explorar una fragancia nueva sin arriesgar.
          </p>
          <a
            href="https://wa.me/59899373372?text=Hola%2C%20me%20gustar%C3%ADa%20consultar%20disponibilidad%20de%20perfumes%20de%20dise%C3%B1ador%20originales%20en%20Uruguay"
            class="btn-whatsapp"
            target="_blank"
            rel="noopener noreferrer"
            title="Consultar disponibilidad de perfumes de diseñador Uruguay"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar disponibilidad
          </a>
        </div>

        <!-- Marcas disponibles -->
        <div class="scale-in">
          <div style="background:var(--color-cream); border:1px solid var(--color-border); padding:2.5rem;">
            <p style="font-size:0.75rem; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:1.5rem;">
              Marcas que manejamos
            </p>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.8rem; margin-bottom:2rem;">
              {[
                'Chanel', 'Dior', 'YSL', 'Carolina Herrera',
                'Giorgio Armani', 'Versace', 'Paco Rabanne', 'Burberry',
                'Hugo Boss', 'Calvin Klein', 'Dolce & Gabbana', 'Givenchy',
              ].map(marca => (
                <div style="
                  padding:0.7rem 1rem;
                  background:var(--color-white);
                  border:1px solid var(--color-border);
                  font-size:0.82rem;
                  font-weight:500;
                  color:var(--color-charcoal);
                  text-align:center;
                ">
                  {marca}
                </div>
              ))}
            </div>
            <p style="font-size:0.78rem; color:var(--color-text-muted); text-align:center; line-height:1.6;">
              ¿No ves la marca que buscás? Consultanos, tenemos acceso a muchas más.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3. BENEFICIOS ─────────────────────────────────────────── -->
  <section
    aria-label="Ventajas de comprar perfumes de diseñador en Aura Perfumes Uruguay"
    style="background:var(--color-cream); padding-block:var(--section-py);"
  >
    <div class="container">
      <div style="text-align:center; margin-bottom:4rem;">
        <p class="section-label fade-in" style="justify-content:center; margin-bottom:1rem;">¿Por qué Aura Perfumes?</p>
        <h2 class="fade-in-up">Experiencia de boutique, precio de mercado real</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:2rem;">
        {[
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
            title: 'Garantía de autenticidad total',
            text: 'Certificados de procedencia en cada perfume. Si no es original, te devolvemos el dinero.',
          },
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>`,
            title: 'Precio más competitivo de Uruguay',
            text: 'Sin los sobrecostos de las perfumerías físicas. Accedés al precio real de mercado.',
          },
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
            title: 'Asesoría antes de comprar',
            text: 'Valentina te explica el perfil olfativo de cada fragancia para que no te decepciones con tu elección.',
          },
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
            title: 'Envío a todo Uruguay',
            text: 'Despachamos desde Paysandú. Llegamos a Montevideo y todos los departamentos del interior.',
          },
        ].map(b => (
          <div class="fade-in-up" style="background:var(--color-white); border:1px solid var(--color-border); padding:2rem;">
            <div style="color:var(--color-rose-deep); margin-bottom:1rem;" set:html={b.icon}></div>
            <h3 style="font-size:1.05rem; margin-bottom:0.6rem;">{b.title}</h3>
            <p style="font-size:0.87rem; color:var(--color-text-muted); line-height:1.7;">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 4. PROCESO ─────────────────────────────────────────────── -->
  <section
    aria-label="Cómo comprar perfumes de diseñador en Aura Perfumes Uruguay"
    style="background:var(--color-white); padding-block:var(--section-py);"
  >
    <div class="container">
      <div style="text-align:center; margin-bottom:4rem;">
        <p class="section-label fade-in" style="justify-content:center; margin-bottom:1rem;">Simple y seguro</p>
        <h2 class="fade-in-up">Tu perfume de diseñador en 4 pasos</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--color-border); max-width:900px; margin-inline:auto;">
        {[
          {
            n: '01',
            title: 'Elegís',
            text: 'Escribinos la marca y fragancia que buscás, o pedí recomendación si no estás segura.',
          },
          {
            n: '02',
            title: 'Confirmamos',
            text: 'Verificamos stock y te enviamos precio final con costo de envío incluido a tu zona.',
          },
          {
            n: '03',
            title: 'Pagás',
            text: 'Transferencia bancaria o Mercado Pago. Rápido, simple y seguro.',
          },
          {
            n: '04',
            title: 'Recibís',
            text: 'Tu perfume original llega a tu puerta en 2-5 días hábiles, bien empaquetado.',
          },
        ].map(paso => (
          <div class="fade-in-up" style="background:var(--color-cream); padding:2.5rem 2rem; text-align:center;">
            <p style="font-family:var(--font-serif); font-size:2.8rem; font-weight:700; color:var(--color-nude-dark); line-height:1; margin-bottom:1rem;">{paso.n}</p>
            <h3 style="font-size:1rem; margin-bottom:0.5rem;">{paso.title}</h3>
            <p style="font-size:0.82rem; color:var(--color-text-muted); line-height:1.7;">{paso.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 5. CTA ──────────────────────────────────────────────────── -->
  <section
    aria-label="Comprar perfume de diseñador original en Uruguay"
    style="
      background:linear-gradient(135deg, #0d0d1a 0%, #1a1535 100%);
      padding-block:5rem;
      text-align:center;
    "
  >
    <div class="container">
      <h2 class="fade-in-up" style="color:#FAF0E6; margin-bottom:1.2rem; max-width:22ch; margin-left:auto; margin-right:auto;">
        ¿Cuál es el perfume de diseñador que buscás?
      </h2>
      <p class="fade-in-up" style="color:rgba(255,255,255,0.6); margin-bottom:2.5rem; max-width:45ch; margin-left:auto; margin-right:auto; line-height:1.8;">
        Escribinos y te confirmamos disponibilidad, precio y tiempo de entrega. Sin compromiso de compra.
      </p>
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:1rem;">
        <a
          href="https://wa.me/59899373372?text=Hola%21%20Busco%20un%20perfume%20de%20dise%C3%B1ador%20original%20en%20Uruguay.%20%C2%BFTienen%20disponibilidad%20de..."
          class="btn-whatsapp"
          target="_blank"
          rel="noopener noreferrer"
          title="Consultar disponibilidad de perfume de diseñador en Uruguay"
          style="font-size:1rem; padding:1.1rem 2.8rem;"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar disponibilidad
        </a>
        <a href="/perfumes-arabes" class="btn-secondary"
          title="Ver perfumes árabes disponibles en Uruguay"
          style="border-color:rgba(255,255,255,0.3); color:rgba(255,255,255,0.8);">
          Ver perfumes árabes
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 900px) {
    section > .container > div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
    section > .container > div[style*="grid-template-columns:repeat(4,1fr)"] {
      grid-template-columns: 1fr 1fr !important;
    }
  }
  @media (max-width: 540px) {
    section > .container > div[style*="grid-template-columns:repeat(4,1fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
